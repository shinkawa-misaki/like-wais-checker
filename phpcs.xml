<?xml version="1.0"?>
<ruleset name="Cognitive Index Checker Coding Standard">
    <description>PHP_CodeSniffer rules for 認知の手すりチェック Lite project</description>

    <file>app</file>
    <file>database/seeders</file>
    <file>tests</file>

    <arg name="colors"/>
    <arg value="sp"/>

    <rule ref="PSR12"/>

    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="150"/>
        </properties>
    </rule>

    <rule ref="Generic.PHP.RequireStrictTypes"/>

    <!-- PHPUnit test methods use snake_case by convention -->
    <rule ref="PSR1.Methods.CamelCapsMethodName">
        <exclude-pattern>tests/*</exclude-pattern>
    </rule>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/bootstrap/*</exclude-pattern>
    <exclude-pattern>*/storage/*</exclude-pattern>
    <exclude-pattern>*/_ide_helper*</exclude-pattern>
</ruleset>
